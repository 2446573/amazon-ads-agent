# DeepSeek API Key (required for AI analysis)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Apify API Token (required for live competitor scraping)
APIFY_API_TOKEN=your_apify_api_token_here

# Flask secret key (any random string)
FLASK_SECRET_KEY=your_random_secret_here

# Contact info (displayed in footer and contact page)
CONTACT_EMAIL=your@email.com
CONTACT_PHONE=your_phone_number
CONTACT_WECHAT=your_wechat_id
